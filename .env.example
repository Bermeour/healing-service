# Entorno: development | production
APP_ENV=development

# Servidor
HOST=0.0.0.0
PORT=8765
WORKERS=1

# Base de conocimiento
# --- Opción 1: SQLite local (default, sin instalación extra) ---
DB_URL=sqlite+aiosqlite:///./healing_knowledge.db

# --- Opción 2: SQL Server (requiere: pip install aioodbc, ODBC Driver 17/18) ---
# DB_URL=mssql+aioodbc://usuario:contraseña@servidor:1433/healing_db?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
#
# Con Windows Authentication (sin usuario/contraseña):
# DB_URL=mssql+aioodbc://@servidor/healing_db?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

# Directorio donde se guardan los snapshots PNG (uno por elemento, por proyecto).
# Apuntarlo FUERA del código del servicio evita mezclar datos con código.
# Windows: BASELINES_PATH=D:/healing-data/baselines
# Linux:   BASELINES_PATH=/var/lib/healing/baselines
BASELINES_PATH=./baselines

# Umbrales de los motores
DOM_SCORE_THRESHOLD=60
CV_CONFIDENCE_THRESHOLD=0.82

# Logs: debug | info | warning | error
LOG_LEVEL=info
LOG_FILE=./logs/healing.log
